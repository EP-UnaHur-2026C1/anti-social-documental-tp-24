            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "http://localhost:5000/usuarios",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"Luca\",\n  \"email\": \"luca@gmail.com\",\n  \"password\": \"1234\"\n}"
            }
